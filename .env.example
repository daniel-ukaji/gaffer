# Copy to .env and fill in. .env is gitignored — never commit real keys.

# Pimlico (bundler + paymaster). Free tier: https://dashboard.pimlico.io
PIMLICO_KEY=pim_xxx
# A Pimlico Sponsorship Policy id, must be ACTIVE and cover Sepolia (testnet).
SPONSORSHIP_POLICY_ID=sp_xxx

# EVM testnet
RPC_URL=https://sepolia.drpc.org
# Payout token (base units, 6dp assumed). For LIVE payouts, mint this to the
# treasury via Pimlico's Test ERC20 Faucet, then set its address here.
TOKEN=0x1c7D4B196Cb0C7B01d743Fbc6116a902379C7238

# Treasury seed (BIP-39). Throwaway for dev. The Safe address is derived from it.
SEED_PHRASE=test test test test test test test test test test test junk

# Set LIVE=1 to broadcast real gasless payouts (treasury must hold TOKEN).
LIVE=0
